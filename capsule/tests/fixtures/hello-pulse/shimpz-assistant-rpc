#!/usr/local/bin/python3
"""Fixed loopback adapter required by the local Assistant Power contract."""

from __future__ import annotations

import http.client
import json
import sys

MAX_BODY = 16 * 1024
MAX_RESPONSE = 32 * 1024


def main() -> int:
    if len(sys.argv) != 3 or sys.argv[1] not in {"GET", "POST"}:
        return 2
    method, path = sys.argv[1:]
    if path not in {"/healthz", "/v1/powers/hello"}:
        return 2
    raw = sys.stdin.buffer.read(MAX_BODY + 1)
    if len(raw) > MAX_BODY:
        return 2
    try:
        payload = json.loads(raw or b"{}")
    except json.JSONDecodeError:
        return 2
    if not isinstance(payload, dict):
        return 2
    encoded = json.dumps(payload, separators=(",", ":")).encode("utf-8") if method == "POST" else None
    connection = http.client.HTTPConnection("127.0.0.1", 8080, timeout=3)
    try:
        headers = {"Content-Type": "application/json", "Content-Length": str(len(encoded))} if encoded else {}
        connection.request(method, path, body=encoded, headers=headers)
        response = connection.getresponse()
        if response.status != 200 or response.getheader("Content-Type") != "application/json":
            return 3
        length = int(response.getheader("Content-Length", "-1"))
        if not 1 <= length <= MAX_RESPONSE:
            return 3
        output = response.read(length + 1)
        if len(output) != length:
            return 3
        decoded = json.loads(output)
        if not isinstance(decoded, dict):
            return 3
        sys.stdout.buffer.write(json.dumps(decoded, separators=(",", ":")).encode("utf-8"))
    except OSError, ValueError, json.JSONDecodeError:
        return 3
    else:
        return 0
    finally:
        connection.close()


if __name__ == "__main__":
    raise SystemExit(main())
